# Give the player the Hamster Guide Book with specific content using 1.21.1+ component syntax (Content Revision 11 - Single Line Command)

give @s adorablehamsterpets:hamster_guide_book[minecraft:written_book_content={title:'Hamster Hints & Tips',author:'The Scarlet Fox',generation:0,resolved:1b,pages:['{"extra":[{"text":"So, you want hamsters?","color":"gold","bold":true,"underlined":true},{"text":"\\n\\nAn admirable, if slightly predictable, goal.\\n\\nThis guide contains dubious wisdom gleaned from watching small rodents. Use at your own risk.\\n\\n","color":"dark_gray"}],"text":""}','{"extra":[{"text":"Getting Started","color":"dark_aqua","bold":true,"underlined":true},{"text":"\\n\\nFirst, you need bait. The good stuff comes from ","color":"dark_gray"},{"text":"Cucumbers","color":"dark_green"},{"text":". Find ","color":"dark_gray"},{"text":"Wild Cucumber Bushes","color":"dark_green"},{"text":" in warmer places - plains, savannas, maybe jungle edges. Right-click em for seeds.","color":"dark_gray"}],"text":""}','{"extra":[{"text":"Getting Started (Cont.)","color":"dark_aqua","bold":true,"underlined":true},{"text":"\\n\\nPlant those ","color":"dark_gray"},{"text":"Cucumber Seeds","color":"dark_green"},{"text":" on farmland. Once grown, harvest the ","color":"dark_gray"},{"text":"Cucumbers","color":"dark_green"},{"text":".\\n\\nNow, the crucial step: craft the cucumber into ","color":"dark_gray"},{"text":"Sliced Cucumber","color":"dark_green"},{"text":". This is what the little fuzzballs actually want.","color":"dark_gray"}],"text":""}','{"extra":[{"text":"SPOILER WARNING","color":"dark_red","bold":true,"underlined":true},{"text":"\\n\\nBeyond this page lie spoilers. If you prefer blissful ignorance, turn back now. Or do not. I am a book, not your conscience.","color":"dark_gray"}],"text":""}','{"extra":[{"text":"Taming Revisited","color":"dark_aqua","bold":true,"underlined":true},{"text":"\\n\\nRight, the actual taming.\\nRemember: ","color":"dark_gray"},{"text":"Sneak","color":"dark_purple"},{"text":". Hold ","color":"dark_gray"},{"text":"Sliced Cucumber","color":"dark_green"},{"text":". Approach slowly. Hope it does not notice your desperation. Repeat until furry friend acquired.","color":"dark_gray"}],"text":""}','{"extra":[{"text":"Basic Care","color":"dark_aqua","bold":true,"underlined":true},{"text":"\\n\\nThey follow. Constantly.\\nRight-click your tamed hamster to make it ","color":"dark_gray"},{"text":"Sit/Stay","color":"dark_purple"},{"text":". It might feign sleep. Right-click again to resume the stalking.","color":"dark_gray"}],"text":""}','{"extra":[{"text":"Feeding: Healing","color":"dark_aqua","bold":true,"underlined":true},{"text":"\\n\\nIf your hamster has had a disagreement with, well, anything, feed it ","color":"dark_gray"},{"text":"seeds or basic crops","color":"dark_green"},{"text":" to patch it up.\\n\\nFor serious healing, craft ","color":"dark_gray"},{"text":"Hamster Food Mix","color":"dark_green"},{"text":" (sunflower seeds, pumpkin seeds, carrot, wheat).","color":"dark_gray"}],"text":""}','{"extra":[{"text":"Feeding: Breeding","color":"dark_aqua","bold":true,"underlined":true},{"text":"\\n\\nIf its healthy, the same basic food might trigger... ","color":"dark_gray"},{"text":"Love Mode","color":"light_purple"},{"text":". Find another hamster also in Love Mode. Stand back. Nature happens.","color":"dark_gray"}],"text":""}','{"extra":[{"text":"Feeding: Pickiness","color":"dark_aqua","bold":true,"underlined":true},{"text":"\\n\\nDo not feed it the same mundane item twice in a row. It has standards. It will refuse.\\n\\nExceptions: ","color":"dark_gray"},{"text":"Hamster Food Mix","color":"dark_green"},{"text":" (gourmet stuff) and ","color":"dark_gray"},{"text":"Steamed Green Beans","color":"gold"},{"text":".","color":"dark_gray"}],"text":""}','{"extra":[{"text":"Feeding: Buffs","color":"dark_aqua","bold":true,"underlined":true},{"text":"\\n\\nThose ","color":"dark_gray"},{"text":"Steamed Green Beans","color":"gold"},{"text":"? (Smelt regular Green Beans). They grant Speed, Strength, Absorption & Regen for 3 mins. Impressive!\\n\\n...But there is a 5 min cooldown before it works again. Less impressive.","color":"dark_gray"}],"text":""}','{"extra":[{"text":"Cheek Pouches","color":"dark_aqua","bold":true,"underlined":true},{"text":"\\n\\nInventory... in their face.\\n","color":"dark_gray"},{"text":"Sneak + Right-click","color":"dark_purple"},{"text":" a tamed hamster to access 6 cheek slots.\\n\\nIf hurt, it will eat ","color":"dark_gray"},{"text":"Hamster Food Mix","color":"dark_green"},{"text":" from its cheeks if available. I spent a whole hour coding that.","color":"dark_gray"}],"text":""}','{"extra":[{"text":"Shoulder Riding","color":"dark_aqua","bold":true,"underlined":true},{"text":"\\n\\nWield ","color":"dark_gray"},{"text":"Cheese","color":"gold"},{"text":". (Milk bucket in crafting yields cheese). Your nearest hamster warps to your shoulder. Its magic. Or possibly just really good cheese.","color":"dark_gray"}],"text":""}','{"extra":[{"text":"Shoulder Perks","color":"dark_aqua","bold":true,"underlined":true},{"text":"\\n\\nYour shoulder companion may alert you to nearby ","color":"dark_gray"},{"text":"Creepers","color":"dark_green"},{"text":" that have noticed you, or shiny ","color":"dark_gray"},{"text":"Diamonds","color":"aqua"},{"text":". Listen for the unique squeaks and sniffs amongst your own panicked breathing.","color":"dark_gray"}],"text":""}','{"extra":[{"text":"Creeper Paranoia","color":"dark_aqua","bold":true,"underlined":true},{"text":"\\n\\nThat panicked squeak? A ","color":"dark_gray"},{"text":"Creeper","color":"dark_green"},{"text":" has targeted YOU. Not just nearby, ","color":"dark_gray"},{"text":"*targeting*","color":"dark_red","italic":true},{"text":".\\n\\nMaybe your hamster is worried its comfy shoulder perch is about to vanish.","color":"dark_gray"}],"text":""}','{"extra":[{"text":"Subterranean Shinies","color":"dark_aqua","bold":true,"underlined":true},{"text":"\\n\\nThose excited sniffs? Your pocket prospector smells ","color":"dark_gray"},{"text":"Diamonds!","color":"aqua","bold":true},{"text":" Checks a 10-block radius.\\n\\nIt pauses between alerts, so listen carefully before you start digging... again.","color":"dark_gray"}],"text":""}','{"extra":[{"text":"The Hamster Yeet","color":"dark_aqua","bold":true,"underlined":true},{"text":"\\n\\nEmergency measure, perhaps?\\nMake sure you are not looking at a block. ","color":"dark_gray"},{"text":"Press G","color":"dark_purple"},{"text":".\\n\\nYour hamster becomes a projectile dealing significant damage and passing out in the process.","color":"dark_gray"}],"text":""}','{"extra":[{"text":"A Note on Keys","color":"dark_red","bold":true,"underlined":true},{"text":"\\n\\nIs ","color":"dark_gray"},{"text":"G","color":"dark_purple"},{"text":" not throwing your hamster? Did you add this mod to an existing world? Woopsy.\\n\\n","color":"dark_gray"},{"text":"Go to: ","color":"dark_gray"},{"text":"Options > Controls > Key Binds","color":"gold"},{"text":".\\nFind ","color":"dark_gray"},{"text":"\\"Throw Hamster,\\"","color":"gold"},{"text":", and set it to ","color":"dark_gray"},{"text":"G","color":"dark_purple"},{"text":" (or your preferred key).","color":"dark_gray"}],"text":""}','{"extra":[{"text":"Harvesting Notes","color":"dark_aqua","bold":true,"underlined":true},{"text":"\\n\\n","color":"dark_gray"},{"text":"Sunflowers","color":"gold"},{"text":" sometimes yield seeds on right-click. They regrow eventually.\\nIf one seems barren, it might just be an old chunk - try finding one in an area you have not explored.","color":"dark_gray"},{"text":"\\n\\n","color":"dark_gray"},{"text":"Wild Bushes","color":"dark_green"},{"text":" drop farmable seeds too.","color":"dark_gray"}],"text":""}']}] 1

